# ============================================================
#  StormWatch — Backend · Variáveis de ambiente (EXEMPLO)
#  Copie este arquivo para `.env` e preencha os valores reais.
#  NUNCA versione o arquivo `.env` (já está no .gitignore).
# ============================================================

# --- Servidor ---
NODE_ENV=development
PORT=4000

# Origens permitidas para CORS (separadas por vírgula).
# Em produção, coloque APENAS o domínio do seu front-end.
CORS_ORIGINS=http://localhost:5173

# --- Autenticação interna ---
# Chave que o front-end envia no header `x-api-key` para falar com o backend.
# Gere uma forte: `openssl rand -hex 32`
APP_API_KEY=troque-esta-chave-em-producao

# Segredo usado para validar o webhook DE ENTRADA (provedor de raios -> nós),
# caso você use push em vez de polling. Verificado via HMAC.
INBOUND_WEBHOOK_SECRET=troque-este-segredo

# --- Fonte de dados de raios ---
# Provider atual: "mock" | "xweather" | "openweather" | "blitzortung"
LIGHTNING_PROVIDER=mock

# --- Fonte de previsão do tempo ---
# "openmeteo" = API real, gratuita e sem chave (padrão) | "mock" = offline
FORECAST_PROVIDER=openmeteo

# Credenciais da API real (preencha quando trocar o provider).
# Ficam SÓ aqui no servidor — nunca vão para o front-end.
XWEATHER_CLIENT_ID=
XWEATHER_CLIENT_SECRET=
OPENWEATHER_API_KEY=

# --- Ponto monitorado (padrão; o front pode sobrescrever) ---
MONITOR_LAT=-25.5306
MONITOR_LON=-49.2939
MONITOR_LABEL=Pinheirinho, Curitiba - PR

# Raio crítico em km: raios dentro disso disparam alerta.
ALERT_RADIUS_KM=30
# Tempo mínimo entre alertas repetidos (anti-spam), em minutos.
ALERT_COOLDOWN_MIN=10

# --- Saída de alerta (WEBHOOK GENÉRICO) ---
# URL para onde POSTaremos o alerta. Plugue aqui depois:
#   - n8n / Make / Zapier  (que então fala com o WhatsApp)
#   - WhatsApp Cloud API (via um pequeno proxy seu)
#   - Twilio
ALERT_WEBHOOK_URL=
# Segredo opcional: assinamos o corpo com HMAC-SHA256 no header `x-signature`.
ALERT_WEBHOOK_SECRET=
